#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	cd /Users/justin.case.trushell/Code/Bomb-Synth/build && $(CMAKE_COMMAND) -P /Users/justin.case.trushell/Code/Bomb-Synth/build/CMakeFiles/VerifyGlobs.cmake
	cd /Users/justin.case.trushell/Code/Bomb-Synth/build && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

